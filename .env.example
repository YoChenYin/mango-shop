# PostgreSQL 資料庫連線
DATABASE_URL="postgresql://user:password@localhost:5432/mangoshop"

# 寄件 SMTP 設定（可使用 Gmail App Password）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="芒芒人海 <your-email@gmail.com>"

# 後台管理密碼
ADMIN_PASSWORD="your-secure-admin-password"

# 網站網址（生產環境請改為實際域名）
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
