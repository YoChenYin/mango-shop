datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customerName    String
  customerEmail   String
  customerPhone   String
  recipientName   String?
  recipientPhone  String?
  deliveryAddress String
  noHolidayDelivery Boolean @default(false)
  notes           String?

  items           OrderItem[]

  subtotal        Float
  shipping        Float
  total           Float

  paymentCode     String?
  paymentDate     String?

  orderStatus     String   @default("PROCESSING")
  paymentStatus   String   @default("UNPAID")
  adminNotes      String?
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  productName String
  variantName String
  price       Float
  quantity    Int
  subtotal    Float
}

model ProductStock {
  variantId   String   @id
  available   Boolean  @default(true)
  stock       Int      @default(0)   // 0 = 不限量；> 0 = 限量
  updatedAt   DateTime @updatedAt
}

model ShippingDiscountSetting {
  id        Int      @id @default(1)
  enabled   Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model ShippingDiscountRule {
  id             String   @id @default(cuid())
  productId      String?  // null = 全部品項加總箱數；有值 = 僅計算該品項箱數
  minBoxes       Int
  discountAmount Int
  createdAt      DateTime @default(now())
}
